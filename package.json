{
	"name": "artifakt",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "node --max-old-space-size=4096 node_modules/vite/bin/vite.js dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:push": "drizzle-kit push",
		"db:seed": "npx tsx src/lib/server/db/seed.ts",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/d3": "^7.4.3",
		"@types/node": "^25.5.0",
		"drizzle-kit": "^0.31.9",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@huggingface/transformers": "^3.8.1",
		"@types/three": "^0.183.1",
		"@xenova/transformers": "^2.17.2",
		"d3": "^7.9.0",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"ml-hclust": "^4.0.0",
		"open-graph-scraper": "^6.11.0",
		"postgres": "^3.4.8",
		"three": "^0.183.2",
		"zod": "^4.3.6"
	}
}
